FROM nominatim_reverse(
        server_name => 'osm',
        lon => 200,
        lat => 50);
ERROR:  longitude out of range: 200.000000
HINT:  longitude must be between -180 and 180
SELECT pg_sleep(2);
-[ RECORD 1 ]
pg_sleep | 

/* boundary values must be ACCEPTED (inclusive endpoints) */
SELECT osm_id IS NOT NULL
FROM nominatim_reverse(
    server_name => 'osm',
    lon => 180,
    lat => 90);
